#!/usr/bin/env python3
"""
Fetch review data from the HCDE 530 API and extract selected fields.

This script:
1. Calls the /reviews endpoint
2. Collects category, helpful_votes, and date fields
3. Prints each result
4. Saves results to CSV
5. Saves a date-sorted CSV (oldest to newest)
"""

from __future__ import annotations

import csv
import json
from pathlib import Path
from typing import Dict, List
from urllib.error import HTTPError, URLError
from urllib.parse import urlencode
from urllib.request import urlopen

BASE_URL = "https://hcde530-week4-api.onrender.com/reviews" #API endpoint used to fetch data
OUTPUT_CSV = Path(__file__).resolve().parent / "category_helpful_votes.csv" #output file path for CSV file 
OUTPUT_CSV_WITH_DATES = (
    Path(__file__).resolve().parent / "category_helpful_votes_dates_chronological.csv"
)
PAGE_SIZE = 100 #the number of records to request per API call per page, occurs repeatedly until no data left (or until limit) 

#fetch review data from API, takes limit (how many reviews to request) and offset (how many reviews to skip) as inputs 
def fetch_reviews(limit: int = PAGE_SIZE, offset: int = 0) -> Dict:
    """Fetch one page of reviews from the API."""
    query = urlencode({"limit": limit, "offset": offset})
    url = f"{BASE_URL}?{query}"
    with urlopen(url) as response:
        return json.loads(response.read().decode("utf-8"))

#function to return data as a list of items, and each item is a dictionary
def collect_category_helpful_votes() -> List[Dict[str, int | str]]:
    """Page through all reviews and keep category/helpful votes/date."""
    rows: List[Dict[str, int | str]] = []
    offset = 0 #tart pagination at 0 

    while True:
        data = fetch_reviews(limit=PAGE_SIZE, offset=offset)
        reviews = data.get("reviews", [])
        returned = data.get("returned", len(reviews))
        total = data.get("total", 0)

        #loop to append rows with the data types that I wanted to fetch 
        for review in reviews:
            rows.append(
                {
                    "category": review.get("category", ""),
                    "helpful_votes": review.get("helpful_votes", 0),
                    "date": review.get("date", ""),
                }
            )

        if offset + returned >= total or returned == 0:
            break

        offset += returned

    return rows

#function to save returned data points as an organized .csv file 
def save_to_csv(rows: List[Dict[str, int | str]], output_path: Path) -> None:
    """Write category/helpful vote rows to CSV."""
    with output_path.open("w", newline="", encoding="utf-8") as csv_file:
        writer = csv.DictWriter(csv_file, fieldnames=["category", "helpful_votes"])
        writer.writeheader()
        for row in rows:
            writer.writerow(
                {
                    "category": row.get("category", ""),
                    "helpful_votes": row.get("helpful_votes", 0),
                }
            )

#another function to create a new .csv file, but sorts based on chronological order (after date also gets fetched)
def save_date_sorted_csv(rows: List[Dict[str, int | str]], output_path: Path) -> None:
    """Write date/category/helpful vote rows sorted chronologically."""
    sorted_rows = sorted(rows, key=lambda row: str(row.get("date", "")))
    with output_path.open("w", newline="", encoding="utf-8") as csv_file:
        writer = csv.DictWriter(
            csv_file, fieldnames=["date", "category", "helpful_votes"]
        )
        writer.writeheader()
        for row in sorted_rows:
            writer.writerow(
                {
                    "date": row.get("date", ""),
                    "category": row.get("category", ""),
                    "helpful_votes": row.get("helpful_votes", 0),
                }
            )

#runs all functions defined above
def main() -> None:
    try:
        rows = collect_category_helpful_votes()
    except (HTTPError, URLError, TimeoutError) as err:
        print(f"Request failed: {err}")
        return

    print("Category | Helpful Votes")
    print("-" * 28)
    for row in rows:
        print(f"{row['category']} | {row['helpful_votes']}")

    save_to_csv(rows, OUTPUT_CSV)
    save_date_sorted_csv(rows, OUTPUT_CSV_WITH_DATES)
    print(f"\nSaved {len(rows)} rows to {OUTPUT_CSV.resolve()}")
    print(f"Saved date-sorted rows to {OUTPUT_CSV_WITH_DATES.resolve()}")


if __name__ == "__main__":
    main()
